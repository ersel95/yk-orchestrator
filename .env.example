# ==============================================================================
# YapıKredi iOS Daily Orchestrator - Environment Configuration
# ==============================================================================
# .env olarak kopyalayıp kendi değerlerini doldur. Bu dosyayı asla commit etme.

# ----- Genel -----
APP_NAME="YK iOS Orchestrator"
APP_ENV=local
LOG_LEVEL=INFO
TIMEZONE=Europe/Istanbul

# ----- Sunucu -----
API_HOST=127.0.0.1
API_PORT=8765
DASHBOARD_PORT=3000

# ----- Veri tabanı -----
DATABASE_URL=sqlite:///./data/orchestrator.db
CHROMA_PERSIST_DIR=./data/chroma

# ----- Yerel LLM (LM Studio veya Ollama) -----
# LM Studio default: http://127.0.0.1:1234/v1
# Ollama OpenAI uyumlu: http://127.0.0.1:11434/v1
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL_GENERAL=qwen2.5-72b-instruct
LLM_MODEL_CODE=qwen2.5-coder-32b-instruct
LLM_MODEL_EMBED=nomic-embed-text
LLM_TIMEOUT_SECONDS=300
LLM_TEMPERATURE=0.3

# ----- Jira (VPN gerekir) -----
JIRA_BASE_URL=https://jira.yapikredi.com.tr
JIRA_EMAIL=ersel.example@yapikredi.com.tr
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=IOS,MOB
JIRA_CURRENT_USER_ACCOUNT_ID=

# ----- Bitbucket (VPN gerekir) -----
BITBUCKET_BASE_URL=https://bitbucket.yapikredi.com.tr
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_WORKSPACE=mobile
BITBUCKET_DEFAULT_REPO=ios-app

# ----- Git lokal -----
LOCAL_REPO_PATH=/Users/ersel/Workspace/ios-app
GIT_DEFAULT_BRANCH=develop

# ----- TestFlight / Fastlane -----
FASTLANE_LANE=beta
FASTLANE_PROJECT_DIR=/Users/ersel/Workspace/ios-app
TESTFLIGHT_AUTO_SUBMIT=false

# ----- Scheduler -----
DAILY_FETCH_HOUR=8
DAILY_FETCH_MINUTE=30

# ----- Güvenlik -----
DASHBOARD_ALLOW_ORIGIN=http://localhost:3000
